# Environment variables for TTAG PWA

# ── Ethereum Configuration ─────────────────────────────────────────────────────
#
# Set this to your private Ethereum JSON-RPC endpoint.
# Example for a self-hosted node at johncharlesmonti.com:
#
#   VITE_ETHEREUM_RPC_URL=https://eth.johncharlesmonti.com
#
# Leave blank to use the public fallback (ethereum.publicnode.com).
#
VITE_ETHEREUM_RPC_URL=

# ── MAGP Integration (optional) ───────────────────────────────────────────────
#
# API base URL for the MAGP (montinode/MAGP) service.
# Install the MAGP package first: npm install github:montinode/MAGP
#
VITE_MAGP_API_URL=
